@page "/"
@using CatalogoWhatsApp.Data
@using CatalogoWhatsApp.Services
@inject ProductoService ProductoService
@inject PedidoService PedidoService
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@rendermode RenderMode.InteractiveServer

<PageTitle>Catálogo de Productos | Tienda Express</PageTitle>

<div class="container mt-5 pb-5">
    <div class="text-center mb-5 p-5 rounded-4 shadow-sm hero-section">
        <h1 class="display-4 fw-bold text-primary">Nuestra Colección</h1>
        <p class="lead text-muted">Explora calidad, selecciona estilo y pide por WhatsApp</p>
    </div>

    @if (productos == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-grow text-primary" role="status"></div>
            <p class="mt-2 text-muted">Sincronizando inventario...</p>
        </div>
    }
    else if (!productos.Any())
    {
        <div class="alert alert-light text-center shadow-sm border-0 py-5" role="alert">
            <h4 class="text-muted">Aún no hay productos en exhibición.</h4>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 animate-in">
            @foreach (var prod in productos)
            {
                <div class="col">
                    <div class="card h-100 producto-card border-0 shadow-sm" @onclick="() => MostrarDetalle(prod)">
                        <div id="cardCarousel-@prod.id_producto" class="carousel slide carousel-fade h-100"
                             data-bs-ride="carousel"
                             data-bs-interval="3000"
                             data-bs-pause="false">
                            <div class="carousel-inner rounded-t-4">
                                @if (prod.Imagenes != null && prod.Imagenes.Any())
                                {
                                    @for (int i = 0; i < prod.Imagenes.Count; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : "")">
                                            <div class="img-wrapper">
                                                <img src="@prod.Imagenes[i].imagen_url" class="d-block w-100" alt="@prod.nombre">
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="carousel-item active">
                                        <div class="img-wrapper">
                                            <img src="images/no-image.png" class="d-block w-100" alt="Sin imagen">
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge category-badge">@prod.Categoria?.nombre</span>
                                <span class="text-success fw-bold">Q @prod.precio</span>
                            </div>
                            <h6 class="card-title fw-bold text-dark mb-1 text-truncate">@prod.nombre</h6>

                            <div class="mb-3">
                                @if (prod.stock > 0)
                                {
                                    <small class="text-muted">
                                        📦 Stock:
                                        <span class="fw-bold @(prod.stock <= 3 ? "text-danger" : "text-dark")">
                                            @prod.stock @(prod.stock == 1 ? "unidad" : "unidades")
                                        </span>
                                    </small>
                                }
                                else
                                {
                                    <span class="badge bg-danger">🚫 AGOTADO</span>
                                }
                            </div>

                            <button type="button" class="btn btn-primary w-100 rounded-pill btn-add-cart @(prod.stock <= 0 ? "disabled opacity-50" : "")"
                            @onclick:stopPropagation @onclick="() => AgregarAlCarrito(prod)">
                                🛒 @(prod.stock <= 0 ? "Sin existencias" : "Añadir al Pedido")
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (carrito.Any())
{
    <div class="cart-floater shadow-lg" @onclick="AbrirResumen">
        <div class="cart-badge">@carrito.Sum(x => x.Cantidad)</div>
        <span class="text-white fs-3">🛒</span>
    </div>
}

<div class="modal fade @(mostrarModal ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.7); backdrop-filter: blur(5px);">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 overflow-hidden shadow-lg">
            @if (productoSeleccionado != null)
            {
                <div class="row g-0">
                    <div class="col-md-6 bg-light d-flex align-items-center">
                        <div id="carouselDetailModal" class="carousel slide w-100" data-bs-ride="false">
                            <div class="carousel-inner p-4">
                                @for (int i = 0; i < productoSeleccionado.Imagenes.Count; i++)
                                {
                                    <div class="carousel-item @(i == 0 ? "active" : "") text-center">
                                        <img src="@productoSeleccionado.Imagenes[i].imagen_url" class="img-fluid rounded-3" style="max-height: 400px; object-fit: contain;">
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 p-5 bg-white position-relative">
                        <button type="button" class="btn-close position-absolute top-0 end-0 m-3" @onclick="CerrarModal"></button>
                        <h2 class="fw-bold text-dark">@productoSeleccionado.nombre</h2>
                        <h3 class="text-success mb-2">Q @productoSeleccionado.precio</h3>
                        <p class="small text-muted mb-4">Disponibles: <b>@productoSeleccionado.stock</b></p>
                        <p class="text-muted">@productoSeleccionado.descripcion</p>
                        <button type="button" class="btn btn-primary btn-lg w-100 rounded-pill mt-4 shadow-sm @(productoSeleccionado.stock <= 0 ? "disabled" : "")"
                                @onclick="() => AgregarAlCarrito(productoSeleccionado)">
                            @(productoSeleccionado.stock <= 0 ? "Agotado" : "🚀 Agregar al Carrito")
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade @(mostrarResumen ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.6);">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header bg-dark text-white text-center">
                <h5 class="modal-title fw-bold w-100">🛒 Mi Carrito</h5>
                <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarResumen = false"></button>
            </div>
            <div class="modal-body p-4">
                @foreach (var item in carrito)
                {
                    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                        <div>
                            <span class="fw-bold">@item.Producto.nombre</span>
                            <div class="text-muted small">Cantidad: @item.Cantidad</div>
                        </div>
                        <div class="text-primary fw-bold">Q @(item.Producto.precio * item.Cantidad)</div>
                    </div>
                }
                <div class="d-flex justify-content-between h4 fw-bold mt-3">
                    <span>Total:</span>
                    <span class="text-success">Q @carrito.Sum(x => x.Producto.precio * x.Cantidad)</span>
                </div>
            </div>
            <div class="modal-footer border-0 p-4">
                <button type="button" class="btn btn-primary btn-lg w-100 rounded-pill py-3 fw-bold shadow" @onclick="AbrirFormularioEnvio">
                    Continuar con el Envío 📍
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade @(mostrarFormularioEnvio ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.8); backdrop-filter: blur(2px);">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold w-100 text-center">🏠 Información de Entrega</h5>
                <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarFormularioEnvio = false"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Nombre</label>
                        <input type="text" @bind="datosPedido.nombre_cliente" class="form-control rounded-3" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">Apellido</label>
                        <input type="text" @bind="datosPedido.apellido_cliente" class="form-control rounded-3" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-bold">Teléfono</label>
                        <input type="tel" @bind="datosPedido.telefono_cliente" class="form-control rounded-3" />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-bold">Dirección Completa</label>
                        <textarea @bind="datosPedido.direccion" class="form-control rounded-3" rows="2"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-bold">Notas o Referencias</label>
                        <input type="text" @bind="datosPedido.instrucciones_envio" class="form-control rounded-3" />
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 p-4">
                <button type="button" class="btn btn-success btn-lg w-100 rounded-pill py-3 fw-bold shadow"
                        @onclick="FinalizarPedido" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Procesando...</span>
                    }
                    else
                    {
                        <span>🚀 Confirmar y Enviar WhatsApp</span>
                    }
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .hero-section {
        background: linear-gradient(120deg, #ffffff 0%, #f3f4f7 100%);
    }

    .producto-card {
        transition: all 0.3s ease;
        cursor: pointer;
        border-radius: 1.2rem;
    }

        .producto-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    .img-wrapper {
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 15px;
        background: #fff;
    }

        .img-wrapper img {
            max-height: 100%;
            object-fit: contain;
        }

    .cart-floater {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: #25D366;
        width: 65px;
        height: 65px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        cursor: pointer;
    }

    .cart-badge {
        position: absolute;
        top: 0;
        right: 0;
        background: #ff3b30;
        color: white;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        font-size: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid white;
        font-weight: bold;
    }

    .animate-in {
        animation: fadeInUp 0.6s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@code {
    private List<Producto>? productos;
    private bool mostrarModal = false;
    private bool mostrarResumen = false;
    private bool mostrarFormularioEnvio = false;
    private bool isSaving = false;

    private Producto? productoSeleccionado;
    private Pedido datosPedido = new Pedido();
    private List<ElementoCarrito> carrito = new List<ElementoCarrito>();

    public class ElementoCarrito
    {
        public Producto Producto { get; set; } = new Producto();
        public int Cantidad { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        productos = await ProductoService.GetProductosAsync();
    }

    private void MostrarDetalle(Producto p) { productoSeleccionado = p; mostrarModal = true; }
    private void CerrarModal() { mostrarModal = false; }
    private void AbrirResumen() { mostrarResumen = true; }
    private void AbrirFormularioEnvio() { mostrarResumen = false; mostrarFormularioEnvio = true; }

    private void AgregarAlCarrito(Producto p)
    {
        if (p.stock <= 0) return;
        var item = carrito.FirstOrDefault(x => x.Producto.id_producto == p.id_producto);
        if (item != null) item.Cantidad++;
        else carrito.Add(new ElementoCarrito { Producto = p, Cantidad = 1 });
        CerrarModal();
    }

    private async Task FinalizarPedido()
    {
        // 1. Validación de seguridad
        if (string.IsNullOrWhiteSpace(datosPedido.nombre_cliente) ||
            string.IsNullOrWhiteSpace(datosPedido.telefono_cliente) ||
            string.IsNullOrWhiteSpace(datosPedido.direccion))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Por favor, completa los campos obligatorios.");
            return;
        }

        try
        {
            isSaving = true;
            StateHasChanged();

            // 2. Preparar detalles
            datosPedido.Detalles = carrito.Select(x => new DetallePedido
                {
                    id_producto = x.Producto.id_producto,
                    cantidad = x.Cantidad,
                    precio_unitario = x.Producto.precio
                }).ToList();

            datosPedido.total_pedido = carrito.Sum(x => x.Producto.precio * x.Cantidad);
            datosPedido.id_estado = 1; // Se guarda inicialmente como Pendiente

            // 3. Guardar en DB y restar stock (en una transacción)
            int idGenerado = await PedidoService.GuardarPedidoAsync(datosPedido);

            // 4. CAMBIO DE ESTADO: Ahora lo pasamos a Estado 2 (Enviado)
            // porque ya estamos listos para saltar a WhatsApp
            await PedidoService.ActualizarEstadoPedidoAsync(idGenerado, 2);

            // 5. Preparar mensaje WhatsApp
            string telefonoEmpresa = "50232152801";
            string msj = $"*NUEVO PEDIDO #{idGenerado}*\n";
            msj += "---------------------------------\n";
            msj += $"👤 *Cliente:* {datosPedido.nombre_cliente} {datosPedido.apellido_cliente}\n";
            msj += $"📞 *Tel:* {datosPedido.telefono_cliente}\n";
            msj += $"📍 *Dirección:* {datosPedido.direccion}\n";
            if (!string.IsNullOrEmpty(datosPedido.instrucciones_envio))
                msj += $"📝 *Nota:* {datosPedido.instrucciones_envio}\n";
            msj += "---------------------------------\n";
            msj += "📦 *PRODUCTOS:*\n";

            foreach (var item in carrito)
            {
                msj += $"• {item.Producto.nombre} (x{item.Cantidad}) - Q{item.Producto.precio * item.Cantidad}\n";
            }
            msj += $"\n💰 *TOTAL A PAGAR: Q{datosPedido.total_pedido}*\n";
            msj += $"🚛 *Método:* Pago Contra Entrega";

            // 6. Limpieza y Navegación
            string url = $"https://wa.me/{telefonoEmpresa}?text={Uri.EscapeDataString(msj)}";

            carrito.Clear();
            datosPedido = new Pedido();
            mostrarFormularioEnvio = false;

            Nav.NavigateTo(url, true);
        }
        catch (Exception ex)
        {
            isSaving = false;
            string errorMsj = ex.InnerException?.Message ?? ex.Message;
            await JSRuntime.InvokeVoidAsync("alert", $"ERROR: {errorMsj}");
            StateHasChanged();
        }
    }
}