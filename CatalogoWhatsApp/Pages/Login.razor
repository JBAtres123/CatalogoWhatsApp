@page "/login"
@using CatalogoWhatsApp.Services
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0 rounded-4 p-4" style="width: 400px;">
        <div class="text-center mb-4">
            <h3 class="fw-bold text-primary">🔐 Acceso Admin</h3>
            <p class="text-muted">Ingresa tus credenciales</p>
        </div>
        <div class="mb-3">
            <label class="form-label">Usuario</label>
            <input type="text" @bind="user" class="form-control rounded-pill" />
        </div>
        <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input type="password" @bind="pass" class="form-control rounded-pill" />
        </div>
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger py-2 small">@error</div>
        }
        <button class="btn btn-primary w-100 rounded-pill py-2 fw-bold" @onclick="HandleLogin">Entrar al Sistema</button>
    </div>
</div>

@code {
    private string user = "";
    private string pass = "";
    private string error = "";

    private async Task HandleLogin()
    {
        if (await AuthService.Login(user, pass)) Nav.NavigateTo("/admin/productos");
        else error = "Credenciales incorrectas";
    }
}