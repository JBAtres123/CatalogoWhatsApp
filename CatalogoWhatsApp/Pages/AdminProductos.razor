@page "/admin/productos"
@using System.IO
@inject IWebHostEnvironment Environment
@using CatalogoWhatsApp.Data
@using CatalogoWhatsApp.Services
@using Microsoft.AspNetCore.Components.Web
@inject ProductoService ProductoService
@inject CategoriaService CategoriaService
@inject NavigationManager Nav
@rendermode RenderMode.InteractiveServer
@inject AuthService AuthService


<PageTitle>Admin - Productos</PageTitle>

<div class="container mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">🛠️ Gestión del Catálogo</h2>
        <div class="btn-group shadow-sm">
            <a href="/admin/productos" class="btn btn-primary active">📦 Productos</a>
            <a href="/admin/pedidos" class="btn btn-outline-primary">📋 Ver Pedidos</a>
        </div>
    </div>
        <div class="card-body p-4 bg-light">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Nombre del Producto</label>
                    <input type="text" @bind="nuevoProd.nombre" class="form-control form-control-lg rounded-3" placeholder="Ej: Tenis Jordan Retro" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Precio (Q)</label>
                    <input type="number" @bind="nuevoProd.precio" class="form-control form-control-lg rounded-3" step="0.01" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Stock Inicial</label>
                    <input type="number" @bind="nuevoProd.stock" class="form-control form-control-lg rounded-3" />
                </div>

                <div class="col-md-12">
                    <label class="form-label fw-bold">Descripción Ampliada</label>
                    <textarea @bind="nuevoProd.descripcion" class="form-control rounded-3" rows="3" placeholder="Describe materiales, tallas, colores..."></textarea>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold">Categoría</label>
                    <select @bind="nuevoProd.id_categoria" class="form-select form-select-lg rounded-3">
                        <option value="0">-- Seleccione una Categoría --</option>
                        @foreach (var cat in categorias)
                        {
                            <option value="@cat.id_categoria">@cat.nombre</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold text-primary">Subir Galería de Imágenes</label>
                    <InputFile @key="inputFileId" OnChange="CargarArchivosLocales" multiple class="form-control form-control-lg rounded-3 border-primary" accept=".jpg,.jpeg,.png,.webp" />

                    @if (archivosSeleccionados.Any())
                    {
                        <div class="mt-3 p-3 bg-white rounded-3 border">
                            <h6 class="fw-bold text-success">📸 @archivosSeleccionados.Count imágenes listas</h6>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="col-12">
                        <div class="alert @(statusMessage.Contains("❌") ? "alert-danger" : "alert-info") py-2 shadow-sm rounded-3">@statusMessage</div>
                    </div>
                }

                <div class="col-12 text-end mt-4">
                    <button class="btn btn-success btn-lg px-5 rounded-pill shadow-sm" @onclick="GuardarCompleto" disabled="@isUploading">
                        @if (isUploading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Subiendo...</span>
                        }
                        else
                        {
                            <span>🚀 Guardar Producto y Galería</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-dark text-white p-3">
            <h5 class="mb-0 fw-bold">Productos en Inventario</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-striped align-middle table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Producto</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Galería</th>
                        <th>Stock Actual</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in listaProductos)
                    {
                        <tr>
                            <td>@p.id_producto</td>
                            <td class="fw-bold">@p.nombre</td>
                            <td>@p.Categoria?.nombre</td>
                            <td class="text-success fw-bold">Q @p.precio.ToString("N2")</td>
                            <td>
                                <span class="badge bg-secondary rounded-pill">
                                    📷 @(p.Imagenes?.Count ?? 0) fotos
                                </span>
                            </td>
                            <td>
                                <span class="fw-bold @(p.stock <= 3 ? "text-danger" : "text-dark")">@p.stock</span>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-outline-danger btn-sm rounded-pill" @onclick="() => Eliminar(p.id_producto)">
                                    <i class="bi bi-trash"></i> Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>


@code {
    private Producto nuevoProd = new() { id_categoria = 0 };
    private List<Producto> listaProductos = new();
    private List<Categoria> categorias = new();
    private Guid inputFileId = Guid.NewGuid();
    private IReadOnlyList<IBrowserFile> archivosSeleccionados = new List<IBrowserFile>();
    private bool isUploading = false;
    private string statusMessage = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await AuthService.IsAuthenticated();
            if (!auth) Nav.NavigateTo("/login");
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await RefrescarDatos();
    }

    private async Task RefrescarDatos()
    {
        listaProductos = await ProductoService.GetProductosAsync();
        categorias = await CategoriaService.GetCategoriasAsync();
    }

    private void CargarArchivosLocales(InputFileChangeEventArgs e)
    {
        archivosSeleccionados = e.GetMultipleFiles(10);
        statusMessage = $"{archivosSeleccionados.Count} archivos seleccionados.";
    }

    private async Task Eliminar(int id)
    {
        if (await ProductoService.EliminarProductoAsync(id))
        {
            await RefrescarDatos();
        }
    }

    private async Task GuardarCompleto()
    {
        if (string.IsNullOrWhiteSpace(nuevoProd.nombre) || nuevoProd.id_categoria == 0)
        {
            statusMessage = "❌ Nombre y Categoría son requeridos.";
            return;
        }

        try
        {
            isUploading = true;
            statusMessage = "⏳ Guardando en DB...";
            StateHasChanged();

            bool insertadoProd = await ProductoService.InsertarProductoAsync(nuevoProd);

            if (insertadoProd)
            {
                int contador = 1;
                foreach (var archivo in archivosSeleccionados)
                {
                    var nombreUnico = $"{Guid.NewGuid()}_{archivo.Name}";
                    var carpeta = Path.Combine(Environment.WebRootPath, "images", "productos");
                    if (!Directory.Exists(carpeta)) Directory.CreateDirectory(carpeta);

                    var rutaFinal = Path.Combine(carpeta, nombreUnico);

                    using var stream = archivo.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5);
                    using var fs = File.Create(rutaFinal);
                    await stream.CopyToAsync(fs);

                    var nuevaImg = new ProductoImagen
                        {
                            id_producto = nuevoProd.id_producto,
                            imagen_url = $"images/productos/{nombreUnico}",
                            es_principal = (contador == 1)
                        };

                    await ProductoService.InsertarImagenProductoAsync(nuevaImg);
                    contador++;
                }

                nuevoProd = new() { id_categoria = 0 };
                inputFileId = Guid.NewGuid();
                archivosSeleccionados = new List<IBrowserFile>();
                statusMessage = "✅ Producto añadido correctamente.";
                await RefrescarDatos();
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"❌ Error: {ex.Message}";
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }
}